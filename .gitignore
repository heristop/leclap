.DS_Store
.vscode/
.idea/
build
coverage
node_modules
dist
.env
.playwright-mcp
test-results
playwright-report

# local smoke-test / preview screenshots
*-smoke.png
form-banner-*.png

# local Claude Code state
.claude/settings.local.json
.claude/scheduled_tasks.lock

# Curated media + fonts are committed once in
# packages/ffmpeg-video-composer/src/shared/library/ (the single source of truth).
# scripts/copy-core-assets.mjs copies them into each app's static dir on dev/build,
# so the generated copies are not tracked.
/apps/le-clap-web/public/musics/
/apps/le-clap-web/public/backgrounds/
/apps/le-clap-web/public/fonts/
/apps/le-clap-expo/assets/musics/
/apps/le-clap-expo/assets/backgrounds/
/apps/le-clap-expo/assets/fonts/
# keep the Expo app's own (non-library) font tracked
!/apps/le-clap-expo/assets/fonts/SpaceMono-Regular.ttf
# server template JSONs copied from packages/server-app/templates by the same script
/apps/le-clap-expo/src/templates/server/

# On-device FFmpeg engine — generated build artifacts (regenerable from source;
# see scripts/ffmpeg/*.sh and packages/ffmpeg-engine/). dist/ + target/ already match above.
/scripts/ffmpeg/.work/
/scripts/ffmpeg/deps/
/packages/ffmpeg-engine/target-host/

# Engine binaries staged into the Expo module — never committed; rebuild with
# scripts/ffmpeg/build-engine.sh (see docs/on-device-compilation.md).
apps/le-clap-expo/modules/leclap-ffmpeg/android/src/main/jniLibs/
apps/le-clap-expo/modules/leclap-ffmpeg/ios/libleclap_ffmpeg_core.a
apps/le-clap-expo/modules/leclap-ffmpeg/ios/LeclapFfmpegCore.xcframework/
