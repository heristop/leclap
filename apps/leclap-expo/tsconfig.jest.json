{
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "module": "CommonJS",
    "target": "ES2024",
    "lib": ["ES2024", "DOM"],
    "jsx": "react-jsx",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["jest", "node"]
  }
}
