            "values": {
              "x": 0,
              "y": 0,
              "w": 1280,
              "h": 720,
              "c": "#0d1b2a@1",
              "t": "fill"
            }
          },
          {
            "type": "drawbox",
            "values": {
              "x": 0,
              "y": 0,
              "w": 1280,
              "h": 150,
              "c": "#13243f@1",
              "t": "fill"
            }
          },
          {
            "type": "drawbox",
            "values": {
              "x": 0,
              "y": 570,
              "w": 1280,
              "h": 150,
              "c": "#13243f@1",
              "t": "fill"
            }
          },
          {
            "type": "drawtext",
            "values": {
              "text": {
                "en": "LeClap"
              },
              "fontcolor": "#f5c518",
              "fontsize": 128,
              "x": "(w-text_w)/2",
              "y": 280,
              "fontfile": "BebasNeue.ttf",
              "alpha": "'if(lt(t,0.4),0,if(lt(t,1.2),(t-0.4)/0.8,1))'"
            }
          },
          {
            "type": "drawbox",
            "values": {
              "x": 540,
              "y": 432,
              "w": 200,
              "h": 5,
              "c": "#f5c518@1",
              "t": "fill"
            }
          },
          {
            "type": "drawtext",
            "values": {
              "text": {
                "en": "made on your device"
              },
              "fontcolor": "#e8eef7",
              "fontsize": 30,
