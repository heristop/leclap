{
  "name": "leclap",
  "private": true,
  "type": "module",
  "author": "heristop",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/heristop/ffmpeg-video-composer.git"
  },
  "scripts": {
    "compile": "node packages/ffmpeg-video-composer/compile.js",
    "diagnose": "node packages/ffmpeg-video-composer/diagnose.js",
    "build": "pnpm -r build",
    "build:exe": "pnpm --filter ffmpeg-video-composer run build:exe",
    "build:exe:all": "pnpm --filter ffmpeg-video-composer run build:exe:all",
    "lint": "vp lint",
    "fmt": "vp fmt",
    "fmt:check": "vp fmt --check",
    "format": "vp fmt",
    "check": "vp check",
    "test": "pnpm -r test",
    "test:ui": "vp test --ui",
    "test:ci": "vp test run --coverage.enabled --coverage.reporter=text-summary",
    "test:coverage": "vp test run --coverage",
    "test:integration": "pnpm --filter ffmpeg-video-composer test:integration && pnpm --filter @leclap/mcp test:integration",
    "test:build": "pnpm --filter ffmpeg-video-composer build && vp test run packages/ffmpeg-video-composer/tests/build-output.test.ts",
    "graph": "madge --dot --extensions ts packages/ffmpeg-video-composer/src/ > graph.dot",
    "deps:check": "depcruise packages/ffmpeg-video-composer/src",
    "deps:graph": "depcruise packages/ffmpeg-video-composer/src --output-type dot | dot -T svg > docs/dependency-graph.svg",
    "deps:html": "depcruise packages/ffmpeg-video-composer/src --output-type html > docs/dependency-report.html",
    "prepare": "vp config",
    "playground:start": "pnpm --filter @leclap/expo run start",
    "playground:android": "pnpm --filter @leclap/expo run android",
    "playground:ios": "pnpm --filter @leclap/expo run ios",
    "playground:web": "pnpm --filter @leclap/web run dev",
    "server:dev": "pnpm --filter ffmpeg-video-composer build && pnpm --filter @leclap/server-app run build && pnpm --filter @leclap/server-app run start",
    "mcp:dev": "pnpm --filter ffmpeg-video-composer build && pnpm --filter @leclap/mcp build && node packages/mcp/dist/index.js"
  },
  "devDependencies": {
    "@swc/core": "^1.15.40",
    "@types/node": "^25.9.2",
    "@vitest/coverage-v8": "^4.1.8",
    "@vitest/ui": "^4.1.8",
    "dependency-cruiser": "^17.4.3",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "unplugin-swc": "^1.5.9",
    "vite-plugin-checker": "^0.14.1",
    "vite-plus": "^0.1.24",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=24.11.0"
  },
  "packageManager": "pnpm@11.5.2"
}
