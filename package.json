{
  "name": "ffmpeg-video-composer",
  "version": "1.1.0",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "ffmpeg-video-composer": "./packages/core/src/cli/executable.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "author": "heristop",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/heristop/ffmpeg-video-composer.git"
  },
  "license": "MIT",
  "scripts": {
    "compile": "node compile.js",
    "diagnose": "node diagnose.js",
    "build:exe": "pkg packages/core/src/cli/executable.js --targets node22-win-x64,node22-macos-x64,node22-linux-x64 --output-path dist/bin",
    "build:exe:all": "pnpm build && pnpm build:exe",
    "lint": "eslint ./packages/core && pnpm --filter le-clap-expo run lint",
    "test": "vitest --run",
    "test:ui": "vitest --ui",
    "test:ci": "vitest run --coverage.enabled --coverage.reporter='text-summary'",
    "test:coverage": "vitest run --coverage",
    "test:precommit": "vitest --run",
    "build": "tsdown",
    "graph": "madge --dot --extensions ts packages/core/src/ > graph.dot",
    "deps:check": "depcruise packages/core/src",
    "deps:graph": "depcruise packages/core/src --output-type dot | dot -T svg > docs/dependency-graph.svg",
    "deps:html": "depcruise packages/core/src --output-type html > docs/dependency-report.html",
    "prepare": "husky",
    "playground:start": "pnpm --filter le-clap-expo run start",
    "playground:android": "pnpm --filter le-clap-expo run android",
    "playground:ios": "pnpm --filter le-clap-expo run ios",
    "playground:web": "pnpm --filter le-clap-web run dev",
    "server:dev": "pnpm --filter server run build && pnpm --filter server run start"
  },
  "type": "module",
  "files": [
    "dist",
    "compile.js",
    "diagnose.js",
    "packages/core/src/cli/executable.js",
    "packages/core/src/shared/templates/**/*.json",
    "README.md"
  ],
  "keywords": [
    "ffmpeg",
    "video-processing",
    "video-editing",
    "ffmpeg-script"
  ],
  "dependencies": {
    "axios": "^1.12.2",
    "boxen": "^8.0.1",
    "cli-spinners": "^3.3.0",
    "extract-zip": "^2.0.1",
    "figlet": "^1.9.3",
    "gradient-string": "^3.0.0",
    "picocolors": "^1.1.1",
    "pino": "^10.0.0",
    "reflect-metadata": "^0.2.2",
    "tsyringe": "^4.10.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.37.0",
    "@swc/core": "^1.13.5",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.7.1",
    "@typescript-eslint/eslint-plugin": "^8.46.0",
    "@typescript-eslint/parser": "^8.46.0",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "dependency-cruiser": "^17.0.2",
    "eslint": "^9.37.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.4",
    "globals": "^16.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.4",
    "pkg": "^5.8.1",
    "prettier": "^3.6.2",
    "ts-jest": "^29.4.5",
    "ts-node": "^10.9.2",
    "tsdown": "^0.15.6",
    "typescript": "^5.9.3",
    "unplugin-swc": "^1.5.7",
    "vite-plugin-checker": "^0.11.0",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=22.14.0"
  },
  "optionalDependencies": {
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.0",
    "ffmpeg-static": "^5.2.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@swc/core",
      "esbuild"
    ]
  },
  "packageManager": "pnpm@10.18.2",
  "pkg": {
    "scripts": "dist/**/*.js",
    "assets": [
      "dist/**/*",
      "packages/core/src/shared/templates/**/*.json"
    ],
    "outputPath": "dist/bin"
  }
}
