{
  "name": "ffmpeg-video-composer",
  "version": "0.4.0-beta.1",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "author": "heristop",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/heristop/ffmpeg-video-composer.git"
  },
  "license": "MIT",
  "scripts": {
    "compile": "node --loader ts-node/esm src/main.ts",
    "lint": "eslint .",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:ci": "vitest run --coverage.enabled --coverage.reporter='text-summary'",
    "test:coverage": "vitest run --coverage",
    "test:precommit": "vitest --run",
    "build": "tsup",
    "graph": "madge --dot --extensions ts src/ > graph.dot",
    "prepare": "husky"
  },
  "tsup": {
    "entry": [
      "src",
      "!src/main.ts",
      "!src/shared/assets/*",
      "!src/shared/assets/**/*"
    ],
    "format": [
      "esm",
      "cjs"
    ],
    "splitting": false,
    "sourcemap": true,
    "dts": true,
    "clean": true,
    "minify": false
  },
  "type": "module",
  "files": [
    "dist"
  ],
  "keywords": [
    "ffmpeg",
    "video-processing",
    "video-editing",
    "ffmpeg-script"
  ],
  "dependencies": {
    "axios": "^1.8.1",
    "extract-zip": "^2.0.1",
    "pino": "^9.6.0",
    "reflect-metadata": "^0.2.2",
    "tsyringe": "^4.8.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@swc/core": "^1.11.7",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.9",
    "@typescript-eslint/eslint-plugin": "^8.26.0",
    "@typescript-eslint/parser": "^8.26.0",
    "@vitest/coverage-v8": "^3.0.7",
    "@vitest/ui": "^3.0.7",
    "eslint": "^9.21.0",
    "eslint-config-prettier": "^10.0.2",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-prettier": "^5.2.3",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "prettier": "^3.5.3",
    "ts-jest": "^29.2.6",
    "ts-node": "^10.9.2",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2",
    "unplugin-swc": "^1.5.1",
    "vite-plugin-checker": "^0.9.0",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.0.7"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@swc/core",
      "esbuild"
    ]
  }
}
