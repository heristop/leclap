{
  "name": "ffmpeg-video-composer",
  "version": "2.0.0-beta.0",
  "description": "Template-driven video composition: one JSON spec renders on Node, in the browser via WebAssembly, and fully on-device on React Native — powered by FFmpeg.",
  "homepage": "https://github.com/heristop/ffmpeg-video-composer#readme",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "browser": "./dist/browser.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "browser": "./dist/browser.js",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "default": "./dist/browser.js"
    },
    "./reactnative": {
      "types": "./dist/reactnative.d.ts",
      "default": "./dist/reactnative.js"
    },
    "./src/*": "./src/*"
  },
  "scripts": {
    "postinstall": "pnpm build",
    "build": "tsdown",
    "prepack": "tsdown",
    "build:watch": "tsdown --watch",
    "compile": "node compile.ts",
    "diagnose": "node diagnose.ts",
    "generate:schema": "tsx scripts/generate-schema-json.ts",
    "typecheck": "tsc --noEmit",
    "test": "vp test run",
    "test:coverage": "vp test run --coverage",
    "test:integration": "pnpm build && NODE_OPTIONS=\"--import tsx/esm\" cucumber-js"
  },
  "dependencies": {
    "axios": "^1.18.0",
    "boxen": "^8.0.1",
    "cli-spinners": "^3.4.0",
    "extract-zip": "^2.0.1",
    "figlet": "^1.11.0",
    "gradient-string": "^3.0.0",
    "picocolors": "^1.1.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "reflect-metadata": "^0.2.2",
    "tslib": "^2.8.1",
    "tsyringe": "^4.10.0",
    "zod": "^4.4.3"
  },
  "optionalDependencies": {
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "expo-file-system": "~56.0.8",
    "ffmpeg-static": "^5.3.0"
  },
  "peerDependenciesMeta": {
    "ffmpeg-static": {
      "optional": true
    }
  },
  "devDependencies": {
    "@cucumber/cucumber": "^13.0.0",
    "@leclap/creative-kit": "workspace:*",
    "@rollup/plugin-replace": "^6.0.3",
    "fake-indexeddb": "^6.2.5",
    "tsdown": "^0.22.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=24.11.0"
  },
  "files": [
    "dist",
    "README.md",
    "MIGRATION.md"
  ],
  "keywords": [
    "ffmpeg",
    "video",
    "video-processing",
    "video-editing",
    "composition",
    "video-composition",
    "templates",
    "browser",
    "wasm",
    "cross-platform",
    "react-native",
    "expo",
    "mobile",
    "on-device",
    "serverless"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/heristop/ffmpeg-video-composer.git",
    "directory": "packages/ffmpeg-video-composer"
  },
  "license": "MIT",
  "author": "heristop"
}
