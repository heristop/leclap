{
  "name": "ffmpeg-video-composer",
  "version": "2.0.0-beta.0",
  "description": "Cross-platform video composition library with template support",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "browser": "./dist/browser.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "ffmpeg-video-composer": "./src/cli/executable.js"
  },
  "exports": {
    ".": {
      "browser": "./dist/browser.js",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "default": "./dist/browser.js"
    },
    "./src/*": "./src/*",
    "./src/index": "./src/index.ts"
  },
  "scripts": {
    "build": "tsdown",
    "build:watch": "tsdown --watch",
    "build:exe": "pkg src/cli/executable.js --targets node24-win-x64,node24-macos-x64,node24-linux-x64 --out-path dist/bin",
    "build:exe:all": "pnpm build && pnpm build:exe",
    "compile": "node compile.js",
    "diagnose": "node diagnose.js",
    "lint": "oxlint src -c .oxlintrc.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "axios": "^1.17.0",
    "boxen": "^8.0.1",
    "cli-spinners": "^3.4.0",
    "extract-zip": "^2.0.1",
    "figlet": "^1.11.0",
    "gradient-string": "^3.0.0",
    "picocolors": "^1.1.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "reflect-metadata": "^0.2.2",
    "tsyringe": "^4.10.0",
    "zod": "^4.4.3"
  },
  "optionalDependencies": {
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "ffmpeg-static": "^5.3.0"
  },
  "peerDependenciesMeta": {
    "ffmpeg-static": {
      "optional": true
    }
  },
  "devDependencies": {
    "@rollup/plugin-replace": "^6.0.3",
    "@yao-pkg/pkg": "^6.20.0",
    "fake-indexeddb": "^6.2.5",
    "tsdown": "^0.22.2",
    "typescript": "^6.0.3"
  },
  "files": [
    "dist",
    "src",
    "compile.js",
    "diagnose.js",
    "README.md"
  ],
  "keywords": [
    "ffmpeg",
    "video",
    "video-processing",
    "video-editing",
    "composition",
    "templates",
    "browser",
    "wasm",
    "cross-platform"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/heristop/ffmpeg-video-composer.git",
    "directory": "packages/ffmpeg-video-composer"
  },
  "license": "MIT",
  "author": "heristop",
  "pkg": {
    "scripts": "dist/**/*.js",
    "assets": [
      "dist/**/*",
      "src/shared/templates/**/*.json"
    ],
    "outputPath": "dist/bin"
  }
}
