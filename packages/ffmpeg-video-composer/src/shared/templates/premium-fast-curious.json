{
  "global": {
    "variables": {
      "optionA": "Tea",
      "optionB": "Coffee"
    },
    "orientation": "landscape",
    "musicEnabled": true,
    "music": {
      "name": "pop.mp3"
    },
    "transition": {
      "type": "fade",
      "duration": 0.2
    },
    "audio": {
      "sourceVolume": 1,
      "normalize": "loudnorm"
    }
  },
