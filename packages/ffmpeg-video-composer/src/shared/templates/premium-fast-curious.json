      "name": "form_1",
      "type": "form",
      "title": {
        "en": "Who's the star?"
      },
      "description": {
        "en": ""
      },
      "options": {
        "fields": [
          {
            "name": "form_1_firstname",
            "maxLength": 20,
            "label": {
              "en": "First name"
            }
          }
        ]
      }
    },
