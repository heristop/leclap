      "form_1_firstname": "Emily",
      "form_1_lastname": "Parker",
      "form_1_job": "Fullstack Developer",
      "form_2_keyword1": "Javascript",
      "form_2_keyword2": "Typescript",
      "form_2_keyword3": "Rust",
      "form_2_keyword4": "Caffeine"
    },
    "music": {
      "name": "point-being",
      "url": "musics/point-being.mp3"
    },
    "orientation": "landscape",
    "musicEnabled": true,
    "transition": {
      "type": "dissolve",
      "duration": 0.5
    },
    "audio": {
      "sourceVolume": 1,
      "normalize": "loudnorm"
    },
