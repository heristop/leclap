{
  "global": {
    "variables": {
      "watermark": "pictures/logo.png",
      "videoOutro": "videos/outro.mp4",
      "animatedIcon": "animations/animation_icons.apng",
      "colorsList": ["rgb(41 37 36)", "rgb(250 250 249)"],
      "form_1_firstname": "Emily",
      "form_1_lastname": "Parker",
      "form_1_job": "Fullstack Developer",
      "form_2_keyword1": "Javascript",
      "form_2_keyword2": "Typescript",
      "form_2_keyword3": "Rust",
      "form_2_keyword4": "Caffeine"
    },
    "music": {
      "name": "point-being",
      "url": "musics/point-being.mp3"
    },
    "orientation": "landscape",
    "musicEnabled": true,
    "transition": {
      "type": "dissolve",
      "duration": 0.5
    },
    "audio": {
      "sourceVolume": 1,
      "normalize": "loudnorm"
    },
    "animations": [
      {
        "url": "animations/light_leak.apng",
        "start": 14,
        "duration": 3,
        "opacity": 0.35
      }
    ]
  },
  "sections": [
    {
      "name": "intro_1",
      "type": "video",
      "transition": { "type": "smoothup", "duration": 0.6 },
      "options": {
        "useVideoSection": "video_1",
        "duration": 6,
        "musicVolume": 0.4
      },
      "inputs": [
        {
          "name": "intertitles_border",
          "url": "animations/rounded_border.apng",
          "type": "animation",
          "options": {
            "fps": 25,
            "position": "0:0",
            "scale": "1280:720",
            "persistent": true
          },
          "filters": []
        },
        {
          "name": "watermark",
          "url": "{{ watermark }}"
        }
      ],
      "maps": [
        {
          "inputs": ["@watermark"],
          "filters": [
            {
              "type": "scale",
              "values": {
                "h": -1,
                "w": 100
              }
            }
          ],
          "outputs": ["scaled_logo"]
        },
        {
          "inputs": ["@video"],
          "options": {
            "useSectionFilters": true
          },
          "outputs": ["video"]
        },
        {
          "inputs": ["@intertitles_border", "scaled_logo"],
          "filters": [
            {
              "type": "overlay",
              "value": "50:50"
            }
          ],
          "outputs": ["animation_and_logo"]
        },
        {
          "inputs": ["video", "animation_and_logo"],
          "filters": [
            {
              "type": "overlay",
              "value": "0:0"
            }
          ],
          "outputs": ["final"]
        }
      ],
      "filters": [
        {
          "type": "boxblur",
          "value": "5"
        },
        {
          "type": "drawbox",
          "values": {
            "x": 0,
            "y": 0,
            "w": 1280,
            "h": 720,
            "c": "{{ color1 }}@0.32",
            "t": "fill"
          }
        },
        {
          "type": "drawtext",
          "values": {
            "text": {
              "en": "{{ form_1_firstname }} {{ form_1_lastname }}"
            },
            "fontcolor": "{{ color2 }}",
            "fontsize": 58,
            "x": "(w-text_w)/2",
            "y": "(h-text_h)/1.4",
            "fontfile": "Rubik+Doodle+Shadow.ttf",
            "alpha": "'if(lt(t,0.5),0,if(lt(t,1.5),(t-0.5)/1,if(lt(t,5),1,if(lt(t,7),(1-(t-6))/1,0))))'"
          }
        },
        {
          "type": "drawtext",
          "values": {
            "text": {
              "en": "“{{ form_1_job }}”"
            },
            "fontcolor": "{{ color2 }}",
            "fontsize": 34,
            "x": "(w-text_w)/2",
            "y": "(h-text_h)/1.4+72",
            "fontfile": "Rubik+Doodle+Shadow.ttf",
            "alpha": "'if(lt(t,0.5),0,if(lt(t,1.5),(t-0.5)/1,if(lt(t,5),1,if(lt(t,7),(1-(t-6))/1,0))))'"
          }
        },
        {
          "type": "fade",
          "values": {
            "t": "out",
            "d": "{{ transitionDuration }}",
            "st": "{{ transitionStartTime }}",
            "color": "{{ color1 }}"
          }
        }
      ]
    },
    {
      "name": "form_1",
      "type": "form",
      "title": {
        "fr": "Des infos avant de commencer",
        "en": "A few info before we start"
      },
      "description": {
        "fr": "",
        "en": ""
      },
      "options": {
        "fields": [
          {
            "name": "form_1_firstname",
            "maxLength": 30,
            "label": {
              "fr": "Prénom",
              "en": "First name"
            }
          },
          {
            "name": "form_1_lastname",
            "maxLength": 30,
            "label": {
              "en": "Last name"
            }
          },
          {
            "name": "form_1_job",
            "maxLength": 40,
            "label": {
              "en": "Your Job"
            }
          }
        ]
      }
    },
    {
      "name": "video_1",
      "type": "project_video",
      "look": "warm",
      "grade": { "contrast": 1.1, "saturation": 1.2, "gamma": 0.96 },
      "motion": [{ "type": "kenburns", "direction": "in", "intensity": 1.1 }],
      "transition": { "type": "pixelize", "duration": 0.4 },
      "title": {
        "en": "Tell us a little bit about you"
      },
      "description": {
        "en": "Tell us your first and last name, the job that you do and the name of your company."
      },
      "options": {
        "duration": 20,
        "musicVolume": 0.1
      },
      "inputs": [
        {
          "name": "animatedIcon",
          "type": "animation",
          "options": {
            "fps": 3.333,
            "position": "600:200",
            "scale": "1280:720",
            "persistent": false
          },
          "filters": []
        }
      ],
      "filters": [
        {
          "type": "vignette",
          "value": "PI/5"
        },
        {
          "type": "drawtext",
          "values": {
            "text": {
              "en": "{{ form_1_firstname }} {{ form_1_lastname }}"
            },
            "fontcolor": "{{ color2 }}",
            "fontsize": 40,
            "x": "(w-tw-40)",
            "y": "(h-th-220)",
            "fontfile": "Rubik.ttf",
            "box": 1,
            "boxcolor": "{{ color1 }}@0.55",
            "boxborderw": 16
          }
        },
        {
          "type": "drawtext",
          "values": {
            "text": {
              "en": "{{ form_1_job }}"
            },
            "fontcolor": "{{ color2 }}",
            "fontsize": 30,
            "x": "(w-tw-40)",
            "y": "(h-th-160)",
            "fontfile": "Rubik.ttf",
            "box": 1,
            "boxcolor": "{{ color1 }}@0.65",
            "boxborderw": 14
          }
        },
        {
          "type": "fade",
          "values": {
            "t": "in",
            "d": "{{ transitionDuration }}",
            "color": "{{ color2 }}"
          }
        },
        {
          "type": "fade",
          "values": {
            "t": "out",
            "d": "{{ transitionDuration }}",
            "st": "{{ transitionStartTime }}",
            "color": "{{ color1 }}"
          }
        }
      ]
    },
    {
      "type": "partial",
      "ref": "flash-card",
      "variables": {
        "optionA": "drink",
        "optionB": "code",
        "conjunction": "&",
        "colorA": "{{ color1 }}",
        "colorB": "{{ color2 }}",
        "textColor": "{{ color2 }}"
      }
    },
    {
      "name": "form_2",
      "type": "form",
      "title": {
        "en": "3 keywords to describe your job"
      },
      "description": {
        "fr": "",
        "en": ""
      },
      "options": {
        "fields": [
          {
            "name": "form_2_keyword1",
            "maxLength": 25,
            "label": {
              "en": "Keyword 1"
            }
          },
          {
            "name": "form_2_keyword2",
            "maxLength": 25,
            "label": {
              "en": "Keyword 2"
            }
          },
          {
            "name": "form_2_keyword3",
            "maxLength": 25,
            "label": {
              "en": "Keyword 3"
            }
          },
          {
            "name": "form_2_keyword4",
            "maxLength": 25,
            "label": {
              "en": "Keyword 4"
            }
          }
        ]
      }
    },
    {
      "name": "video_2",
      "type": "project_video",
      "look": "warm",
      "grade": { "contrast": 1.1, "saturation": 1.2, "gamma": 0.96 },
      "motion": [{ "type": "kenburns", "direction": "in", "intensity": 1.1 }],
      "transition": { "type": "coverleft", "duration": 0.5 },
      "title": {
        "en": "Make your speech"
      },
      "description": {
        "en": "What are you going to make us discover?"
      },
      "options": {
        "duration": 45,
        "musicVolume": 0.1
      },
      "filters": [
        {
          "type": "drawtext",
          "values": {
            "text": {
              "en": "Languages"
            },
            "fontcolor": "{{ color1 }}",
            "fontsize": 34,
            "x": "w-text_w-12",
            "y": 60,
            "fontfile": "Rubik+Doodle+Shadow.ttf",
            "box": 1,
            "boxcolor": "{{ color2 }}@0.75",
            "boxborderw": 12
          }
        },
        {
          "type": "drawtext",
          "values": {
            "text": {
              "fr": "{{ form_2_keyword1 }}",
              "en": "{{ form_2_keyword1 }}"
            },
            "fontcolor": "{{ color2 }}",
            "fontsize": 30,
            "x": "w-text_w-12",
            "y": 160,
            "fontfile": "Rubik+Doodle+Shadow.ttf",
            "box": 1,
            "boxcolor": "{{ color1 }}@0.75",
            "boxborderw": 12
          }
        },
        {
          "type": "drawtext",
          "values": {
            "text": {
              "fr": "{{ form_2_keyword2 }}",
              "en": "{{ form_2_keyword2 }}"
            },
            "fontcolor": "{{ color2 }}",
            "fontsize": 30,
            "x": "w-text_w-12",
            "y": 240,
            "fontfile": "Rubik+Doodle+Shadow.ttf",
            "box": 1,
            "boxcolor": "{{ color1 }}@0.75",
            "boxborderw": 12
          }
        },
        {
          "type": "drawtext",
          "values": {
            "text": {
              "en": "{{ form_2_keyword3 }}"
            },
            "fontcolor": "{{ color2 }}",
            "fontsize": 30,
            "x": "w-text_w-12",
            "y": 320,
            "fontfile": "Rubik+Doodle+Shadow.ttf",
            "box": 1,
            "boxcolor": "{{ color1 }}@0.75",
            "boxborderw": 12
          }
        },
        {
          "type": "drawtext",
          "values": {
            "text": {
              "en": "{{ form_2_keyword4 }}"
            },
            "fontcolor": "{{ color2 }}",
            "fontsize": 30,
            "x": "w-text_w-12",
            "y": 400,
            "fontfile": "Rubik+Doodle+Shadow.ttf",
            "box": 1,
            "boxcolor": "{{ color1 }}@0.75",
            "boxborderw": 12
          }
        },
        {
          "type": "fadein",
          "values": {
            "color": "{{ color1 }}"
          }
        },
        {
          "type": "fadeout",
          "values": {
            "color": "{{ color1 }}"
          }
        }
      ]
    },
    {
      "name": "form_3",
      "type": "form",
      "title": {
        "en": "Describe your work environment"
      },
      "description": {
        "fr": "",
        "en": ""
      }
    },
    {
      "name": "video_3",
      "type": "project_video",
      "look": "warm",
      "grade": { "contrast": 1.1, "saturation": 1.2, "gamma": 0.96 },
      "transition": { "type": "circleclose", "duration": 0.7 },
      "title": {
        "en": "Show the work environment"
      },
      "description": {},
      "options": {
        "duration": 180,
        "speed": 0.25,
        "muteSection": true,
        "musicVolume": 0.4
      },
      "maps": [
        {
          "inputs": ["1:v"],
          "filters": [
            {
              "type": "setpts",
              "value": "0.25*PTS"
            }
          ],
          "outputs": ["final"]
        }
      ],
      "filters": [
        {
          "type": "drawtext",
          "values": {
            "text": {
              "en": "{{ form_3_keyword1 }}"
            },
            "fontcolor": "{{ color2 }}",
            "fontsize": 36,
            "x": "(w-tw-40)",
            "y": "(h-th-160)",
            "fontfile": "Rubik+Doodle+Shadow.ttf",
            "box": 1,
            "boxcolor": "{{ color1 }}@0.5",
            "boxborderw": 10
          }
        },
        {
          "type": "fadein",
          "values": {
            "color": "{{ color1 }}"
          }
        },
        {
          "type": "fadeout",
          "values": {
            "color": "{{ color1 }}"
          }
        }
      ]
    },
    {
      "name": "outro",
      "type": "video",
      "look": "warm",
      "grade": { "contrast": 1.1, "saturation": 1.2, "gamma": 0.96 },
      "options": {
        "videoUrl": "{{ videoOutro }}",
        "duration": 5,
        "musicVolume": 0.2
      },
      "filters": [
        {
          "type": "fadein",
          "values": {
            "color": "{{ color1 }}"
          }
        },
        {
          "type": "fadeout",
          "values": {
            "color": "{{ color1 }}"
          }
        },
        {
          "type": "drawtext",
          "values": {
            "text": {
              "en": "Thank you for watching!"
            },
            "fontcolor": "{{ color2 }}",
            "fontsize": 60,
            "x": "(w-text_w)/2",
            "y": "(h-text_h)/1.4",
            "fontfile": "Rubik+Marker+Hatch.ttf",
            "alpha": "'if(lt(t,0.5),0,if(lt(t,1.5),(t-0.5)/1,if(lt(t,5),1,if(lt(t,7),(1-(t-6))/1,0))))'"
          }
        }
      ]
    },
    {
      "name": "music_1",
      "type": "music",
      "title": {
        "en": "Pick your music"
      },
      "description": {
        "en": ""
      },
      "options": {}
    }
  ]
}
