{
  "meta": {
    "name": "App Tutorial",
    "description": "A square how-to for your app — record a screen walkthrough and get a captioned tutorial with a step pill and a clean title card."
  },
  "global": {
    "orientation": "square",
    "variables": {
      "brand": "YOUR APP"
    },
    "musicEnabled": true,
    "music": {
      "name": "the-builder.mp3"
    },
    "allowedMusic": ["the-builder", "lofi-hip-hop", "point-being", "upbeat-electronic", "lofi-chill"],
    "allowUploadMusic": true,
    "transition": {
      "type": "fade",
      "duration": 0.5
    },
    "audio": {
      "sourceVolume": 1,
      "musicVolume": 0.22
    },
    "overlays": [
      {
        "text": { "en": "{{ brand }}" },
        "position": "top-right",
        "color": "#5eead4",
        "size": 28,
        "reveal": "fade"
      }
    ]
  },
  "sections": [
    {
      "name": "form_1",
      "type": "form",
      "title": {
        "en": "Your tutorial"
      },
      "description": {
        "en": "What you're teaching and the step shown over your screen recording"
      },
      "options": {
        "fields": [
          {
            "name": "form_1_topic",
            "maxLength": 22,
            "label": {
              "en": "What you'll show"
            }
          },
          {
            "name": "form_1_step",
            "maxLength": 38,
            "label": {
              "en": "Step caption"
            }
          }
        ]
      }
    },
    {
      "name": "intro",
      "type": "color_background",
      "transition": {
        "type": "fade",
        "duration": 0.4
      },
      "titleCard": {
        "kicker": { "en": "HOW TO" },
        "headline": { "en": "{{ form_1_topic }}" },
        "subtitle": { "en": "a quick walkthrough" },
        "accent": "#2dd4bf",
        "reveal": "slide-left"
      },
      "options": {
        "backgroundColor": "#0f1419",
        "duration": 2.6
      }
    },
    {
      "name": "video_1",
      "type": "project_video",
      "look": "cool",
      "inputs": [
        {
          "name": "tutorial_frame",
          "url": "/assets/animations/tap_pulse.apng",
          "type": "animation",
          "options": { "loop": true, "persistent": true, "position": "0:0", "scale": "1080:1080", "opacity": 0.9 }
        }
      ],
      "lowerThird": {
        "title": { "en": "{{ form_1_step }}" },
        "badge": { "en": "STEP" },
        "accent": "#2dd4bf",
        "reveal": "rise"
      },
      "title": {
        "en": "Record your screen"
      },
      "description": {
        "en": "Walk through the app — the step caption appears along the bottom"
      },
      "options": {
        "duration": 10,
        "forceAspectRatio": true,
        "countdown": true,
        "countdownDuration": 2,
        "musicVolume": 0.1
      },
      "filters": [
        {
          "type": "vignette"
        }
      ]
    },
    {
      "name": "outro",
      "type": "color_background",
      "titleCard": {
        "headline": { "en": "YOU'RE ALL SET" },
        "subtitle": { "en": "{{ brand }}" },
        "accent": "#2dd4bf",
        "align": "center",
        "reveal": "rise",
        "fade": { "out": false }
      },
      "options": {
        "backgroundColor": "#0f1419",
        "duration": 2.2
      }
    }
  ]
}
