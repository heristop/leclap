{
  "meta": {
    "name": "Interview",
    "description": "An 'on the record' name card, then your answer with a branded lower-third name and title."
  },
  "global": {
    "orientation": "landscape",
    "musicEnabled": true,
    "music": {
      "name": "lofi-sentimental-jazz.mp3"
    },
    "allowedMusic": ["lofi-sentimental-jazz", "cafe-jazz", "lofi-chill", "cafe-bossa-nova", "romantic-piano"],
    "allowUploadMusic": true,
    "transition": {
      "type": "fade",
      "duration": 0.4
    },
    "audio": {
      "sourceVolume": 1,
      "musicVolume": 0.18,
      "normalize": "loudnorm"
    }
  },
  "sections": [
    {
      "name": "form_1",
      "type": "form",
      "title": {
        "en": "Who's on camera?"
      },
      "description": {
        "en": ""
      },
      "options": {
        "fields": [
          {
            "name": "form_1_name",
            "maxLength": 24,
            "label": {
              "en": "Name"
            }
          },
          {
            "name": "form_1_title",
            "maxLength": 32,
            "label": {
              "en": "Title / role"
            }
          },
          {
            "name": "form_1_question",
            "maxLength": 48,
            "label": {
              "en": "Question to answer"
            }
          }
        ]
      }
    },
    {
      "name": "intro",
      "type": "color_background",
      "transition": {
        "type": "smoothright",
        "duration": 0.4
      },
      "options": {
        "backgroundColor": "#0d1b2a",
        "duration": 2.6
      },
      "filters": [
        {
          "type": "drawbox",
          "values": {
            "x": 0,
            "y": 0,
            "w": 1280,
            "h": 720,
            "c": "#0d1b2a@1",
            "t": "fill"
          }
        },
        {
          "type": "drawbox",
          "values": {
            "x": 0,
            "y": 0,
            "w": 1280,
            "h": 150,
            "c": "#13243f@1",
            "t": "fill"
          }
        },
        {
          "type": "drawbox",
          "values": {
            "x": 0,
            "y": 570,
            "w": 1280,
            "h": 150,
            "c": "#13243f@1",
            "t": "fill"
          }
        },
        {
          "type": "drawtext",
          "values": {
            "text": {
              "en": "ON THE RECORD"
            },
            "fontcolor": "#9aa7c7",
            "fontsize": 30,
            "x": "(w-text_w)/2",
            "y": 232,
            "fontfile": "Oswald.ttf",
            "alpha": "'if(lt(t,0.3),0,if(lt(t,1.0),(t-0.3)/0.7,1))'"
          }
        },
        {
          "type": "drawtext",
          "values": {
            "text": {
              "en": "{{ form_1_name }}"
            },
            "fontcolor": "#7C83FD",
            "fontsize": 112,
            "x": "(w-text_w)/2",
            "y": 300,
            "fontfile": "BebasNeue.ttf",
            "alpha": "'if(lt(t,0.6),0,if(lt(t,1.5),(t-0.6)/0.9,1))'"
          }
        },
        {
          "type": "drawbox",
          "values": {
            "x": 540,
            "y": 446,
            "w": 200,
            "h": 4,
            "c": "#7C83FD@1",
            "t": "fill"
          }
        },
        {
          "type": "drawtext",
          "values": {
            "text": {
              "en": "{{ form_1_title }}"
            },
            "fontcolor": "#e8eef7",
            "fontsize": 34,
            "x": "(w-text_w)/2",
            "y": 470,
            "fontfile": "Oswald.ttf",
            "alpha": "'if(lt(t,1.0),0,if(lt(t,1.8),(t-1.0)/0.8,1))'"
          }
        },
        {
          "type": "vignette"
        },
        {
          "type": "fade",
          "values": {
            "t": "in",
            "d": "0.6",
            "color": "#0d1b2a"
          }
        },
        {
          "type": "fade",
          "values": {
            "t": "out",
            "d": "{{ transitionDuration }}",
            "st": "{{ transitionStartTime }}",
            "color": "#0d1b2a"
          }
        }
      ]
    },
    {
      "name": "video_1",
      "type": "project_video",
      "look": "cinematic",
      "caption": {
        "text": {
          "en": "{{ form_1_question }}"
        },
        "style": "bar",
        "position": "top",
        "align": "center"
      },
      "title": {
        "en": "Answer the question"
      },
      "description": {
        "en": "Look at the camera and answer — your name sits in the lower-third"
      },
      "options": {
        "duration": 15,
        "forceAspectRatio": true,
        "countdown": true,
        "countdownDuration": 2,
        "musicVolume": 0.08,
        "framingGuide": {
          "type": "silhouette",
          "position": "center"
        }
      },
      "filters": [
        {
          "type": "vignette"
        },
        {
          "type": "drawbox",
          "values": {
            "x": 0,
            "y": 566,
            "w": 840,
            "h": 116,
            "c": "#0d1b2a@0.62",
            "t": "fill"
          }
        },
        {
          "type": "drawbox",
          "values": {
            "x": 0,
            "y": 566,
            "w": 8,
            "h": 116,
            "c": "#7C83FD@1",
            "t": "fill"
          }
        },
        {
          "type": "drawtext",
          "values": {
            "text": {
              "en": "{{ form_1_name }}"
            },
            "fontcolor": "#f5f5f0",
            "fontsize": 50,
            "x": 40,
            "y": 584,
            "fontfile": "Oswald.ttf",
            "alpha": "'if(lt(t,0.3),0,if(lt(t,1.0),(t-0.3)/0.7,1))'"
          }
        },
        {
          "type": "drawtext",
          "values": {
            "text": {
              "en": "{{ form_1_title }}"
            },
            "fontcolor": "#9aa7c7",
            "fontsize": 26,
            "x": 40,
            "y": 644,
            "fontfile": "Oswald.ttf",
            "alpha": "'if(lt(t,0.6),0,if(lt(t,1.3),(t-0.6)/0.7,1))'"
          }
        },
        {
          "type": "fadein",
          "values": {
            "color": "#0d1b2a"
          }
        },
        {
          "type": "fadeout",
          "values": {
            "color": "#0d1b2a"
          }
        }
      ]
    },
    {
      "type": "partial",
      "ref": "logo-bumper"
    }
  ]
}
