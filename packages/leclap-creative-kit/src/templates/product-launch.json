{
  "meta": {
    "name": "Product Launch",
    "description": "A vertical product reveal — record your product in action and get a promo with its name, pitch and price as a lower third, framed by an animated focus reticle."
  },
  "global": {
    "orientation": "portrait",
    "variables": {
      "brand": "YOUR BRAND"
    },
    "musicEnabled": true,
    "music": {
      "name": "upbeat-electronic.mp3"
    },
    "allowedMusic": ["upbeat-electronic", "future-bass-energy", "the-builder", "indie-rock-dreamy", "arcadia"],
    "allowUploadMusic": true,
    "transition": {
      "type": "fade",
      "duration": 0.5
    },
    "audio": {
      "sourceVolume": 1,
      "musicVolume": 0.28
    },
    "overlays": [
      {
        "text": { "en": "{{ brand }}" },
        "position": "top-right",
        "color": "#ffffff",
        "size": 26,
        "reveal": "fade"
      }
    ]
  },
  "sections": [
    {
      "name": "form_1",
      "type": "form",
      "title": {
        "en": "Your product"
      },
      "description": {
        "en": "The name, one-line pitch and price shown over your clip"
      },
      "options": {
        "fields": [
          {
            "name": "form_1_name",
            "maxLength": 16,
            "label": {
              "en": "Product name"
            }
          },
          {
            "name": "form_1_tagline",
            "maxLength": 40,
            "label": {
              "en": "One-line pitch"
            }
          },
          {
            "name": "form_1_price",
            "maxLength": 12,
            "label": {
              "en": "Price or offer"
            }
          }
        ]
      }
    },
    {
      "name": "intro",
      "type": "color_background",
      "transition": {
        "type": "smoothup",
        "duration": 0.5
      },
      "titleCard": {
        "kicker": { "en": "INTRODUCING" },
        "headline": { "en": "{{ form_1_name }}" },
        "subtitle": { "en": "{{ form_1_tagline }}" },
        "accent": "#7C83FF",
        "reveal": "slide-left"
      },
      "options": {
        "backgroundColor": "#0b0e24",
        "duration": 2.8
      }
    },
    {
      "name": "video_1",
      "type": "project_video",
      "look": "vivid",
      "inputs": [
        {
          "name": "reticle",
          "url": "/assets/animations/spec_orbit.apng",
          "type": "animation",
          "options": { "loop": true, "persistent": true, "position": "0:0", "scale": "720:1280", "opacity": 0.55 }
        }
      ],
      "lowerThird": {
        "title": { "en": "{{ form_1_name }}" },
        "subtitle": { "en": "{{ form_1_tagline }}" },
        "badge": { "en": "{{ form_1_price }}" },
        "accent": "#7C83FF",
        "reveal": "rise"
      },
      "title": {
        "en": "Show your product"
      },
      "description": {
        "en": "Film it in action — the focus reticle locks on while the price slides in"
      },
      "options": {
        "duration": 8,
        "forceAspectRatio": true,
        "countdown": true,
        "countdownDuration": 2,
        "musicVolume": 0.14
      },
      "filters": [
        {
          "type": "vignette"
        }
      ]
    },
    {
      "name": "outro",
      "type": "color_background",
      "titleCard": {
        "headline": { "en": "AVAILABLE NOW" },
        "subtitle": { "en": "{{ form_1_price }}" },
        "accent": "#7C83FF",
        "align": "center",
        "reveal": "rise",
        "fade": { "out": false }
      },
      "options": {
        "backgroundColor": "#0b0e24",
        "duration": 2.4
      }
    }
  ]
}
