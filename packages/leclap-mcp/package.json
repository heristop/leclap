{
  "name": "@leclap/mcp",
  "version": "0.1.0",
  "description": "MCP server exposing ffmpeg-video-composer as agent-callable video composition tools",
  "author": "heristop",
  "license": "MIT",
  "type": "module",
  "bin": {
    "leclap-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "embed-templates": "node scripts/embed-templates.ts",
    "build": "tsdown",
    "prepack": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "vp test run",
    "test:integration": "pnpm --filter ffmpeg-video-composer build && pnpm build && NODE_OPTIONS=\"--import tsx/esm\" cucumber-js"
  },
  "dependencies": {
    "@leclap/creative-kit": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ffmpeg-video-composer": "workspace:*",
    "reflect-metadata": "^0.2.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^13.0.0",
    "@types/node": "^25.9.3",
    "tsdown": "^0.22.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=24.11.0"
  }
}
