{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["es2024", "dom"],
    "types": ["node"],
    "skipLibCheck": true,
    "paths": {
      "ffmpeg-video-composer": ["../ffmpeg-video-composer/dist"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
