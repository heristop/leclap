{
  "global": {
    "variables": {
      "colorsList": ["#FFFFFF", "#333333"]
    },
    "music": {
      "name": "default",
      "url": "https://github.com/heristop/ffmpeg-video-composer/raw/main/src/shared/assets/musics/go-by-ocean.mp3"
    },
    "orientation": "portrait",
    "musicEnabled": true,
    "transition": {
      "type": "cut",
      "duration": 0.5
    },
    "audio": {
      "sourceVolume": 1
    }
  },
  "sections": [
    {
      "name": "form_1",
      "type": "form",
      "title": {
        "en": "Keyword"
      },
      "description": {
        "en": "Describe yourself in 1 word"
      },
      "options": {
        "fields": [
          {
            "name": "form_1_keyword1",
            "maxLength": 15,
            "label": {
              "en": "Keyword"
            }
          }
        ]
      }
    },
    {
      "name": "portrait",
      "type": "project_video",
      "title": {
        "en": "Your Portrait"
      },
      "options": {
        "useVideoSection": "video_portrait",
        "duration": 6,
        "musicVolume": 0.4
      },
      "inputs": [],
      "maps": [],
      "filters": [
        {
          "type": "boxblur",
          "value": "5"
        },
        {
          "type": "drawbox",
          "values": {
            "x": 0,
            "y": 0,
            "w": "iw",
            "h": "ih",
            "c": "{{ color2 }}@0.15",
            "t": "fill"
          }
        },
        {
          "type": "drawtext",
          "values": {
            "text": {
              "en": "“{{ form_1_keyword1 }}”"
            },
            "fontcolor": "{{ color1 }}",
            "fontsize": 50,
            "x": "w-text_w-20",
            "y": "(h-text_h)/1.4+180",
            "fontfile": "Quicksand.ttf",
            "alpha": "'if(lt(t,0.5),0,if(lt(t,1.5),(t-0.5)/1,if(lt(t,5),1,if(lt(t,7),(1-(t-6))/1,0))))'"
          }
        },
        {
          "type": "fade",
          "values": {
            "t": "out",
            "d": "{{ transitionDuration }}",
            "st": "{{ transitionStartTime }}",
            "color": "#000000"
          }
        }
      ]
    }
  ]
}
