{
  "global": {
    "variables": {
      "colorsList": ["#FFFFFF", "#6C5CE7"]
    },
    "orientation": "portrait",
    "musicEnabled": false,
    "transition": {
      "type": "cut",
      "duration": 0.5
    },
    "audio": {
      "sourceVolume": 1
    }
  },
  "sections": [
    {
      "name": "form_1",
      "type": "form",
      "title": {
        "en": "Quick Card"
      },
      "description": {
        "en": "Type a short message to put on your video"
      },
      "options": {
        "fields": [
          {
            "name": "form_1_message",
            "maxLength": 20,
            "label": {
              "en": "Message"
            }
          }
        ]
      }
    },
    {
      "name": "intro",
      "type": "color_background",
      "title": {
        "en": "Intro"
      },
      "options": {
        "backgroundColor": "#6C5CE7",
        "duration": 3
      },
      "filters": [
        {
          "type": "drawbox",
          "values": {
            "x": 0,
            "y": 0,
            "w": 720,
            "h": 1280,
            "c": "#6C5CE7@1",
            "t": "fill"
          }
        },
        {
          "type": "drawtext",
          "values": {
            "text": {
              "en": "{{ form_1_message }}"
            },
            "fontcolor": "#FFFFFF",
            "fontsize": 90,
            "x": "(w-text_w)/2",
            "y": "(h-text_h)/2",
            "fontfile": "Quicksand.ttf"
          }
        }
      ]
    }
  ]
}
