{
  "extends": "../../tsconfig.json", // Extend the root config
  "compilerOptions": {
    "outDir": "./dist", // Specify an output directory for the server package
    "rootDir": "./src",
    "emitDecoratorMetadata": true, // Crucial for tsyringe
    "experimentalDecorators": true, // Crucial for tsyringe
    "module": "NodeNext", // Use NodeNext for modern Node.js ESM compatibility
    "moduleResolution": "NodeNext",
    "paths": {
      // Ensure workspace dependency can be resolved if needed, though pnpm should handle this
      "ffmpeg-video-composer": ["../ffmpeg-video-composer/dist"] // Point to the built output of the library package
    }
  },
  "include": ["src/**/*"], // Only include the server's source files
  "exclude": ["node_modules", "dist"]
}
