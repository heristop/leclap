# Pinned versions for the on-device FFmpeg engine build.
# FFmpeg n8.0 matches rsmpeg 0.18 (`0.18.0+ffmpeg.8.0`); validated against the Rust core in P1.
FFMPEG_VERSION=n8.0
FREETYPE_VERSION=VER-2-13-3   # only needed for drawtext (added in P3)
HARFBUZZ_VERSION=8.5.0        # FFmpeg 8.0 drawtext hard-requires libharfbuzz (text-shaping rewrite)
OPENH264_VERSION=2.5.0        # Cisco LGPL-compatible software H.264 encoder
ANDROID_API=24
ANDROID_ABIS="arm64-v8a armeabi-v7a x86_64"
IOS_MIN=13.0
# NDK to use (newest 27.x present on this machine).
NDK_VERSION=27.1.12297006
